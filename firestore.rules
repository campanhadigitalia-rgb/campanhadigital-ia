rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções auxiliares de Segurança
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isProprietor() {
      return isSignedIn() && getProfile().role == 'Proprietor';
    }

    function isAdmin() {
      return isSignedIn() && (getProfile().role == 'Admin' || getProfile().role == 'Proprietor');
    }

    function isCampaignAdmin(campaignId) {
      let camp = get(/databases/$(database)/documents/campaigns/$(campaignId));
      return camp != null && camp.data.admin_email == request.auth.token.email;
    }

    function hasCampaignAccess(campaignId) {
      return isProprietor() || (isSignedIn() && (
        campaignId == getProfile().campaign_id || 
        campaignId in getProfile().campaigns || 
        isCampaignAdmin(campaignId)
      ));
    }

    // Regras por Coleção
    
    // Organizações - Apenas Proprietários
    match /organizations/{orgId} {
      allow read, write: if isProprietor();
    }

    // Usuários - Dono ou Proprietário
    match /users/{userId} {
      allow read, write: if isProprietor() || (request.auth != null && request.auth.uid == userId);
    }

    // Campanhas - Admin ou Proprietário
    match /campaigns/{campaignId} {
      allow read, write: if isProprietor() || (isSignedIn() && resource.data.admin_email == request.auth.token.email);
      allow create: if isProprietor();

      // Permitir acesso a sub-coleções (fornecedores, vaquinhas, etc.)
      match /{subCollection}/{docId} {
        allow read, write: if isProprietor() || isCampaignAdmin(campaignId) || (isSignedIn() && getProfile().campaign_id == campaignId);
      }
    }

    // Transações Financeiras (Coleção Legada/Top-level se usada)
    match /finance_transactions/{docId} {
      allow read, write: if isProprietor() || (
        isSignedIn() && 
        (
          ('campaign_id' in resource.data && hasCampaignAccess(resource.data.campaign_id)) ||
          ('campaign_id' in request.resource.data && hasCampaignAccess(request.resource.data.campaign_id))
        )
      );
      allow create: if isSignedIn() && 'campaign_id' in request.resource.data && hasCampaignAccess(request.resource.data.campaign_id);
    }

    // Outras coleções (Multi-Tenant isolado por campaign_id)
    match /{collection}/{docId} {
      allow read, write: if isProprietor() || (
        isSignedIn() && 
        (
          (resource != null && 'campaign_id' in resource.data && hasCampaignAccess(resource.data.campaign_id)) ||
          (request.resource != null && 'campaign_id' in request.resource.data && hasCampaignAccess(request.resource.data.campaign_id))
        )
      );
      
      allow create: if isProprietor() || (
        isSignedIn() && 
        'campaign_id' in request.resource.data && 
        hasCampaignAccess(request.resource.data.campaign_id)
      );
    }
  }
}
