rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function hasCampaignAccess(cid) {
      return isAuth() && 
             cid != null && 
             cid != "" && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' || 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.campaign_id == cid || 
               (cid in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.campaigns)
             );
    }

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /campaigns/{campaignId} {
      allow read: if isAuth();
      allow write: if isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /{collection}/{docId} {
      allow read: if isAuth() && 
                    collection != 'users' && 
                    collection != 'campaigns' && 
                    hasCampaignAccess(resource.data.campaign_id);
      
      allow write: if isAuth() && 
                     collection != 'users' && 
                     collection != 'campaigns' && 
                     hasCampaignAccess(request.resource.data.campaign_id || (resource != null ? resource.data.campaign_id : ""));
    }
  }
}
