rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // O usuário acessa apenas campanhas que estejam ativas no perfil dele
    // ou constem na lista de campanhas do perfil
    function hasCampaignAccess(cid) {
      let profile = getProfile();
      return profile != null && (profile.campaign_id == cid || cid in profile.campaigns || profile.role == 'admin');
    }

    match /users/{userId} {
      // Usuário pode ler/escrever o próprio perfil
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Regra global: todo documento deve possuir um campaign_id atrelado (Multi-tenant check)
    match /{collection}/{docId} {
      allow read: if isAuth() && hasCampaignAccess(resource.data.campaign_id);
      allow create: if isAuth() && hasCampaignAccess(request.resource.data.campaign_id);
      allow update, delete: if isAuth() && hasCampaignAccess(resource.data.campaign_id);
    }
  }
}
