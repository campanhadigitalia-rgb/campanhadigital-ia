# Configurações do Firebase (Obrigatório)
VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto_id
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_id
VITE_FIREBASE_APP_ID=seu_app_id
VITE_FIREBASE_MEASUREMENT_ID=seu_measurement_id

# ──────────────────────────────────────────────────────────────
# Integração Meta AI / Manus AI (Contexto de Agentes)
# ──────────────────────────────────────────────────────────────
VITE_META_AI_ENDPOINT=https://api.meta.ai/v1
VITE_META_AI_API_KEY=sua_meta_ai_key_aqui
VITE_MANUS_AI_API_KEY=sua_manus_ai_key_aqui
